{
  "name": "@miqaat/electron",
  "version": "1.0.0",
  "private": true,
  "description": "Miqāt desktop shell",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.json && cross-env NODE_ENV=development electron .",
    "build": "tsc -p tsconfig.json",
    "start": "electron .",
    "rebuild-native": "electron-builder install-app-deps",
    "package": "electron-builder install-app-deps && electron-builder --publish=never",
    "release": "electron-builder install-app-deps && electron-builder --publish=always",
    "release:draft": "electron-builder install-app-deps && electron-builder --publish=onTagOrDraft",
    "install:prod-deps": "npm install --no-workspaces --install-strategy=nested --omit=dev"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "adhan": "^4.4.3",
    "axios": "^1.7.7",
    "better-sqlite3": "^11.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.9",
    "luxon": "^3.5.0",
    "multer": "^1.4.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.developbettersolutions.miqaat",
    "productName": "Miqaat",
    "electronVersion": "34.5.8",
    "asar": true,
    "directories": {
      "output": "dist-build"
    },
    "files": [
      "dist/**/*",
      "resources/**/*",
      "node_modules/**/*",
      "!node_modules/**/*.md",
      "!node_modules/**/test/**",
      "!node_modules/**/.bin/**"
    ],
    "extraResources": [
      { "from": "../server/dist", "to": "server" },
      { "from": "../client/dist", "to": "client" }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": ["zip", "dir"],
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": ["zip", "dir"],
      "icon": "resources/icon.png"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://updates.miqaaat.com/",
        "channel": "latest"
      },
      {
        "provider": "github",
        "owner": "bdevgroup",
        "repo": "miqaat",
        "releaseType": "release"
      }
    ]
  }
}
